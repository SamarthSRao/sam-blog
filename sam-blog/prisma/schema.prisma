// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  engineType = "library"

}


  datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
  }


